# =============================================
# RAGBuddy Environment Configuration
# =============================================
# Copy this file to backend/.env and fill in values

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Database (swap to postgresql+asyncpg://... for prod) ---
DATABASE_URL=sqlite+aiosqlite:///./ragbuddy.db

# --- Storage paths ---
KB_STORAGE_PATH=../kb_storage
UPLOAD_DIR=./uploads

# --- Per-agent model assignments ---
# StructuringAgent: background batch task — Sonnet is 40% cheaper than Opus,
#   supports adaptive thinking + JSON output. Upgrade to opus for max quality.
CLAUDE_STRUCTURING_MODEL=claude-sonnet-4-6

# SynthesisAgent: user-facing streaming answer — keep Opus for quality.
CLAUDE_SYNTHESIS_MODEL=claude-opus-4-6

# SuggestionAgent: KB gap analysis (classification task) — Haiku is correct.
CLAUDE_SUGGESTION_MODEL=claude-haiku-4-5-20251001

# Skills (categorize, summarize, extract_entities, detect_gaps) — Haiku.
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# Kept for backward compat (not actively used by agents — see per-agent vars above)
CLAUDE_MODEL=claude-opus-4-6

# --- Per-agent effort levels ---
# Controls reasoning depth and token spend via output_config.effort.
# Valid values: low | medium | high | max
# NOTE: effort is NOT supported on Haiku 4.5 — it is omitted automatically.
# max is Opus 4.6-only.
STRUCTURING_EFFORT=medium
SYNTHESIS_EFFORT=high
SUGGESTION_EFFORT=low

# --- Retry & resilience ---
# SDK-level retry (covers streaming). App-level retry adds exponential backoff
# for non-streaming calls (StructuringAgent, SuggestionAgent).
API_MAX_RETRIES=3
API_RETRY_BASE_DELAY=1.0
API_RETRY_MAX_DELAY=30.0

# --- Parallel ingestion ---
# Max concurrent Anthropic API calls during batch ingestion.
# Raise carefully — higher values increase rate limit risk.
MAX_PARALLEL_INGESTIONS=3

# --- Retrieval ---
BM25_TOP_K=10
SEMANTIC_RERANK_ENABLED=false

# --- Upload limits ---
MAX_UPLOAD_SIZE_MB=50

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO
