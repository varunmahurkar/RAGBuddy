# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Per-agent model assignments (defaults shown) ──────────────────────────────
# Structuring: converts raw documents into KB articles (background batch task)
STRUCTURING_MODEL=gpt-4o-mini

# Synthesis: generates the streaming answer shown to the user (quality-critical)
SYNTHESIS_MODEL=gpt-4o-mini

# Suggestion: identifies KB gaps after answering (light analysis)
SUGGESTION_MODEL=gpt-4o-mini

# Skills: classify/extract/summarize (short calls — cheapest model)
SKILLS_MODEL=gpt-4o-mini

# Other OpenAI model options:
#   gpt-4o          — higher quality, higher cost
#   gpt-4o-mini     — default; good quality/cost balance
#   gpt-3.5-turbo   — cheapest; lower quality on complex tasks

# ── Retry & scaling ───────────────────────────────────────────────────────────
API_MAX_RETRIES=3
API_RETRY_BASE_DELAY=1.0
API_RETRY_MAX_DELAY=30.0
MAX_PARALLEL_INGESTIONS=3

# ── Storage paths ─────────────────────────────────────────────────────────────
KB_STORAGE_PATH=./data/kb
UPLOAD_DIR=./data/uploads
DATABASE_URL=sqlite+aiosqlite:///./data/ragbuddy.db

# ── App settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
SEMANTIC_RERANK_ENABLED=false
